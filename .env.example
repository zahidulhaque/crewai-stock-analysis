# CrewAI Stock Analysis Configuration - OpenAI Compatible API

# Required: Your API key for the LLM endpoint
API_KEY=your_api_key_here

# Required: Model ID or path (e.g., meta-llama/Llama-3.1-8B-Instruct)
MODEL_ID=meta-llama/Llama-3.1-8B-Instruct

# Required: Base URL for your OpenAI-compatible API endpoint
# Examples:
#   - Local vLLM: http://localhost:8000/v1
#   - OpenAI: https://api.openai.com/v1
#   - Other providers: Check their documentation
MODEL_BASE_URL=http://localhost:8000/v1
