# CrewAI Stock Analysis Configuration

# Option 1: Groq API (Recommended - Free tier available)
# Get your API key from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Option 2: Local/OpenAI Compatible API
# Use this if you have a local LLM or OpenAI-compatible endpoint
API_KEY=your_api_key
MODEL_ID=your_model_id_or_path
MODEL_BASE_URL=http://localhost:8000  # Your model endpoint URL

